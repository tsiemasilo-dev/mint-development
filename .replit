modules = ["nodejs-20", "web", "swift-5.8", "postgresql-16"]
[agent]
expertMode = true
integrations = ["resend:1.0.0", "javascript_anthropic_ai_integrations:2.0.0"]
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"
packages = ["unzip"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 3002
externalPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 8000

[[ports]]
localPort = 5002
externalPort = 3002

[[ports]]
localPort = 5003
externalPort = 4200

[[ports]]
localPort = 5004
externalPort = 3003

[[ports]]
localPort = 5005
externalPort = 6000

[[ports]]
localPort = 5173
externalPort = 5173

[deployment]
deploymentTarget = "static"
build = ["npm", "run", "build"]
publicDir = "dist"

[userenv]

[userenv.shared]
VITE_API_KEY = "${API_KEY}"
TRUID_DOMAIN = "truidconnect.io"
TRUID_API_BASE = "https://api.truidconnect.io"
TRUID_SCHEME = "https"
COMPANY_ID = "AlgoLend"
REDIRECT_URL = "https://98c53c65-2d21-45be-85d9-9955243bdc05-00-345u4hugvanos.spock.replit.dev/onboarding?step=3"
WEBHOOK_URL = "https://98c53c65-2d21-45be-85d9-9955243bdc05-00-345u4hugvanos.spock.replit.dev/api/truid/webhook"
SUMSUB_LEVEL_NAME = "mint-advanced-kyc"
OZOW_IS_TEST = "false"
VITE_SUPABASE_URL = "https://mfxnghmuccevsxwcetej.supabase.co"
SUMSUB_BASE_URL = "api.sumsub.com"
API_PORT = "3001"
NODE_ENV = "development"
EXPERIAN_MOCK = "true"
EXPERIAN_MOCK_MODE = "true"

[userenv.development]
VITE_ENABLE_INSURE = "true"
APP_URL = "https://mint-development.vercel.app"

[userenv.production]
APP_URL = "https://app.mymint.co.za"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
